       "[(1, u1*u2*u3),\n",
       " (1, u1*u3*y1),\n",
       " (1, u2*u3*y1),\n",
       " (1/2, u3*y1^2),\n",
       " (1, u1*u2*y2),\n",
       " (1, u1*u3*y2),\n",
       " (1, u2*u3*y2),\n",
       " (1, u1*y1*y2),\n",
       " (1, u2*y1*y2),\n",
       " (1, u3*y1*y2),\n",
       " (1/2, y1^2*y2),\n",
       " (1/2, u1*y2^2),\n",
       " (1/2, u2*y2^2),\n",
       " (1/2, u3*y2^2),\n",
       " (1/2, y1*y2^2),\n",
       " (1/6, y2^3)]"
      ]
     },
     "execution_count": 10,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "P = PolynomialRing(QQ, 'u1,u2,u3,y1,y2')\n",
    "u1,u2,u3,y1,y2 = P.gens()\n",
    "\n",
    "sym = u1*u2*u3 + (y1 + y2) * u2*u3 + (y1+y2)*u1*u3 + y2*u1*u2 + (y1*y2 + y2^2/2)*u1 + (y1*y2 + y2^2/2)*u2+ (y1^2/2 + y1*y2 + y2^2/2)*u3 + (y1^2*y2/2 + y1*y2^2/2 + y2^3/6)\n",
    "\n",
    "list(sym)"
   ]
  }
 ],
